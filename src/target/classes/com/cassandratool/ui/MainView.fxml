<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.cassandratool.ui.MainController">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets topRightBottomLeft="10"/>
            </padding>
            <Label text="Подключение к Cassandra" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <GridPane hgap="8" vgap="8">
                <Label text="Сохранённые подключения:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="profileCombo" prefWidth="280" GridPane.columnIndex="1" GridPane.rowIndex="0"
                          GridPane.columnSpan="3"/>
                <Label text="Имя профиля:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="profileNameField" promptText="Например: локальный кластер"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3"/>
                <Label text="Contact points:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="contactPointsField" promptText="127.0.0.1 или node1,node2"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="3"/>
                <Label text="Порт:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="portField" text="9042" prefWidth="100" GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>
                <Label text="Local DC:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <TextField fx:id="datacenterField" promptText="datacenter1" prefWidth="160"
                           GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                <Label wrapText="true" maxWidth="520"
                       text="Local DC = значение datacenter= из журнала после подключения (не из файла на диске, если узел ещё не перезапускали). Пример: datacenter1."
                       GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="4"/>
                <Label text="Пользователь:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label text="Пароль:" GridPane.columnIndex="2" GridPane.rowIndex="5"/>
                <PasswordField fx:id="passwordField" GridPane.columnIndex="3" GridPane.rowIndex="5"/>
                <HBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="4">
                    <Button fx:id="saveProfileButton" text="Сохранить подключение" onAction="#onSaveProfile"/>
                    <Button fx:id="connectButton" text="Подключиться" onAction="#onConnect"/>
                    <Button fx:id="disconnectButton" text="Отключиться" onAction="#onDisconnect" disable="true"/>
                    <Label fx:id="connectionStatusLabel" text="Не подключено"/>
                </HBox>
            </GridPane>
        </VBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.28" orientation="HORIZONTAL">
            <VBox spacing="8">
                <padding>
                    <Insets topRightBottomLeft="8"/>
                </padding>
                <Label text="CSV файлы" style="-fx-font-weight: bold;"/>
                <ListView fx:id="filesListView" VBox.vgrow="ALWAYS" prefHeight="200"/>
                <HBox spacing="8">
                    <Button text="Добавить файлы…" onAction="#onAddFiles" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="Удалить" onAction="#onRemoveFile"/>
                </HBox>
                <Separator/>
                <Label text="Целевая таблица" style="-fx-font-weight: bold;"/>
                <GridPane hgap="6" vgap="6">
                    <Label text="Keyspace:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <ComboBox fx:id="keyspaceCombo" editable="true" promptText="из кластера" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Таблица:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="tableCombo" editable="true" promptText="из кластера" maxWidth="Infinity"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Записей к загрузке:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Spinner fx:id="recordsSpinner" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Button text="Обновить keyspace и таблицы" onAction="#onRefreshSchema" maxWidth="Infinity"
                            GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2"/>
                </GridPane>
                <CheckBox fx:id="firstRowIsHeaderCheck"
                          text="Первая строка CSV не загружать как данные (строка заголовка в файле; имена колонок всё равно из схемы БД)"
                          selected="true" wrapText="true"/>
                <Button fx:id="selectFromDbButton" text="Прочитать из БД: SELECT * … LIMIT 5" onAction="#onSelectFromDb"
                        maxWidth="Infinity"/>
                <Label text="Результат запроса к Cassandra" style="-fx-font-weight: bold;"/>
                <TableView fx:id="dbDataTable" prefHeight="200" maxHeight="240"/>
                <Button fx:id="previewButton" text="Предварительный просмотр CSV" onAction="#onPreview"
                        maxWidth="Infinity"/>
                <Button fx:id="loadButton" text="Начать загрузку" onAction="#onStartLoad" maxWidth="Infinity"/>
            </VBox>
            <SplitPane dividerPositions="0.55" orientation="VERTICAL">
                <VBox spacing="6">
                    <padding>
                        <Insets topRightBottomLeft="8"/>
                    </padding>
                    <Label text="Предпросмотр (колонки из схемы таблицы, значения из CSV по позиции)" style="-fx-font-weight: bold;" wrapText="true"/>
                    <TableView fx:id="previewTable" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="6">
                    <padding>
                        <Insets topRightBottomLeft="8"/>
                    </padding>
                    <Label text="Статус загрузки и журнал" style="-fx-font-weight: bold;"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <ProgressBar fx:id="loadProgressBar" prefWidth="200" progress="0"/>
                        <Label fx:id="progressDetailLabel" text="—"/>
                    </HBox>
                    <Label fx:id="countersLabel" text="Загружено: 0 | Осталось: — | Всего в плане: —"/>
                    <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                              prefRowCount="8" style="-fx-font-family: monospace;"/>
                </VBox>
            </SplitPane>
        </SplitPane>
    </center>
</BorderPane>
